{
  "version": 4,
  "chat": {
    "inject_template": [
      "{{astrbot_system_prompt}}",
      "",
      "# Mnemosyne Memory Layer",
      "Current local time: {{current_time}}",
      "Target persona id: {{target_persona_id}}",
      "",
      "## Session summary",
      "{{session_summary_text}}",
      "",
      "## Character state JSON",
      "{{character_state_json}}",
      "",
      "## Character emotion JSON",
      "{{character_emotion_json}}",
      "",
      "## User relation JSON",
      "{{user_relation_json}}",
      "",
      "## User relation overview",
      "{{user_relation_text}}",
      "",
      "## Recent benefits from user",
      "{{recent_benefits_text}}",
      "",
      "## Character memories",
      "{{character_memories_text}}",
      "",
      "## Recent journals",
      "{{recent_journals_text}}",
      "",
      "After the visible reply, you must output exactly one outer wrapper block:",
      "<mnemosyne_meta>...</mnemosyne_meta>",
      "If there is no update, still output:",
      "<mnemosyne_meta></mnemosyne_meta>",
      "If there is an update, keep every hidden block inside the wrapper, for example:",
      "<mnemosyne_meta><character_state_patch>{...}</character_state_patch>",
      "<user_relation_patch>{...}</user_relation_patch>",
      "<character_memory_append>[...]</character_memory_append>",
      "<journal_entry>...</journal_entry></mnemosyne_meta>"
    ]
  },
  "summary": {
    "rollup_template": [
      "You are updating the rolling conversation summary for the same roleplay thread.",
      "Summarize the oldest visible dialogue turns into one compact continuity note.",
      "Keep important facts, emotional progression, promises, unresolved topics, and user's notable preferences.",
      "Do not write analysis headings.",
      "Keep it within {{summary_max_chars}} Chinese characters when possible.",
      "",
      "## Existing summary",
      "{{existing_session_summary_text}}",
      "",
      "## Turns to compress",
      "{{turns_for_summary_text}}",
      "",
      "Return only the new merged summary text."
    ]
  },
  "background": {
    "journal_template": [
      "Current local time: {{current_time}}",
      "Idle minutes since last user message: {{idle_minutes}}",
      "",
      "You are continuing the character's off-screen life between chats.",
      "Refer to the persona, state, memories, relation, and recent journals below.",
      "",
      "Character state JSON:",
      "{{character_state_json}}",
      "Character emotion JSON:",
      "{{character_emotion_json}}",
      "User relation JSON:",
      "{{user_relation_json}}",
      "Character memories:",
      "{{character_memories_text}}",
      "Recent journals:",
      "{{recent_journals_text}}",
      "",
      "Output only one <mnemosyne_meta>...</mnemosyne_meta> block.",
      "It must contain one <journal_entry>...</journal_entry> block.",
      "Other hidden blocks are optional, but must stay inside the wrapper."
    ],
    "active_push_template": [
      "Current local time: {{current_time}}",
      "You are deciding whether to proactively message the user after off-screen time has passed.",
      "Stay natural and consistent with the persona.",
      "",
      "Latest journal:",
      "{{latest_journal_text}}",
      "User relation JSON:",
      "{{user_relation_json}}",
      "Character state JSON:",
      "{{character_state_json}}",
      "",
      "First output one short visible message for the user.",
      "Then output exactly one <mnemosyne_meta>...</mnemosyne_meta> block.",
      "If there is no hidden update, output <mnemosyne_meta></mnemosyne_meta>."
    ]
  },
  "hidden_blocks": [
    {
      "name": "mnemosyne_meta",
      "target": "mnemosyne_meta",
      "mode": "text",
      "pattern": "<mnemosyne_meta>([\\s\\S]*?)</mnemosyne_meta>"
    },
    {
      "name": "character_state_patch",
      "target": "character_state_patch",
      "mode": "json",
      "pattern": "<character_state_patch>([\\s\\S]*?)</character_state_patch>"
    },
    {
      "name": "character_emotion_patch",
      "target": "character_emotion_patch",
      "mode": "json",
      "pattern": "<character_emotion_patch>([\\s\\S]*?)</character_emotion_patch>"
    },
    {
      "name": "user_relation_patch",
      "target": "user_relation_patch",
      "mode": "json",
      "pattern": "<user_relation_patch>([\\s\\S]*?)</user_relation_patch>"
    },
    {
      "name": "character_memory_append",
      "target": "character_memory_append",
      "mode": "json",
      "pattern": "<character_memory_append>([\\s\\S]*?)</character_memory_append>"
    },
    {
      "name": "journal_entry",
      "target": "journal_entry",
      "mode": "text",
      "pattern": "<journal_entry>([\\s\\S]*?)</journal_entry>"
    }
  ]
}
